{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3021",
    "build": "next build",
    "postbuild": "node scripts/verify-static-export.mjs",
    "export": "next build",
    "start": "serve out -l 3000",
    "preview": "npm run build && serve out -l 3000",
    "pack:static": "npm run build && tar -caf site-static.zip -C out .",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "npm run lint && npm run build && playwright test",
    "cassette:knockout": "node scripts/knockout-cassette.mjs",
    "cursor:discount-png": "node scripts/cur-17-to-png.mjs",
    "assets:street-notes": "node scripts/optimize-street-notes.mjs",
    "assets:street-notes:alpha": "node scripts/knockout-street-notes-alpha.mjs && node scripts/optimize-street-notes.mjs",
    "assets:pog-cap": "node scripts/knockout-pog-cap-alpha.mjs",
    "assets:compress": "node scripts/compress-public-images.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "serve": "^14.2.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
